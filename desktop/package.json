{
  "name": "animal-adoption-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "萌宠之家 — 桌面壳（加载线上或本地 Next 站点）",
  "author": "animal-adoption",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:mac:x64": "electron-builder --mac --x64",
    "dist:mac:arm64": "electron-builder --mac --arm64",
    "dist:mac:universal": "electron-builder --mac --universal",
    "dist:win": "electron-builder --win",
    "dist:win:portable": "electron-builder --win portable",
    "dist:mac:zip": "electron-builder --mac zip"
  },
  "build": {
    "appId": "top.animal-adoption.desktop",
    "productName": "萌宠之家",
    "copyright": "Copyright © animal-adoption",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.cjs",
      "preload.cjs"
    ],
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "dmg": {
      "title": "animal-adoption ${version}-${arch}",
      "format": "UDZO",
      "writeUpdateInfo": false
    }
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^25.1.8"
  }
}
