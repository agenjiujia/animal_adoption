# 复制为 .env 后填写真实值（勿提交密钥到仓库）

# Prisma / MySQL（与 init_pet_adopt_db.sql 中建库名一致，默认 pet_adopt）
# 格式: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:YOUR_PASSWORD@127.0.0.1:3306/pet_adopt"

# 兼容旧代码或运维脚本（可选；业务以 DATABASE_URL 为准）
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD="YOUR_PASSWORD"
MYSQL_DATABASE="pet_adopt"

# JWT（登录必需）
JWT_SECRET="请替换为足够长的随机字符串"
